{
  "name": "codex-hosted",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "attach-anchors": "tsx src/bin/attachAnchors.ts",
    "build:bridge": "vite build --config vite.bridge.config.ts",
    "launch:unpacked:server": "http-server ./scratch/asar/webview -a localhost -p 5175 -c-1",
    "launch:unpacked": "NODE_ENV=development CODEX_CLI_PATH=$(which codex) electron ./scratch/asar",
    "predevserver": "yarn build:bridge",
    "replace-anchors": "tsx src/bin/replaceAnchors.ts",
    "devserver": "tsx src/bin/devserver.ts"
  },
  "repository": "git@github.com:0xcaff/codex-hosted.git",
  "author": "martin <martincharles07@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@electron/asar": "^4.2.0",
    "@openai/codex": "^0.120.0",
    "electron": "41.2.0",
    "http-server": "^14.1.1",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
